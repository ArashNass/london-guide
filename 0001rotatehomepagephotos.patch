From 957384f6d6c2cbc3cc93b1af8426ed98b82fc338 Mon Sep 17 00:00:00 2001
From: Claude <noreply@anthropic.com>
Date: Tue, 21 Jul 2026 09:46:54 +0000
Subject: [PATCH] Rotate homepage category photos from local image pools

Each homepage tile (except Pubs, which has no local photo folder yet)
now cross-fades through its category's uploaded images instead of a
single hardcoded Google Sites hotlink, which could break at any time.

Also switch the venue-photo deploy step to copy whole image folders
instead of listing files one by one, so newly added photos deploy
automatically instead of needing a matching workflow edit.
---
 .github/workflows/deploy-pages.yml | 83 ++++----------------------
 site.part00                        | 92 ++++++++++++++++++++++++++++-
 site.part01                        | 93 +++++++++++++++++++++++++++++-
 site.part02                        | 93 +++++++++++++++++++++++++++++-
 site.part03                        | 93 +++++++++++++++++++++++++++++-
 site.part04                        | 93 +++++++++++++++++++++++++++++-
 site.part05                        | 25 ++++++++
 7 files changed, 495 insertions(+), 77 deletions(-)
 create mode 100644 site.part05

diff --git a/.github/workflows/deploy-pages.yml b/.github/workflows/deploy-pages.yml
index bed3227..53b2d03 100644
--- a/.github/workflows/deploy-pages.yml
+++ b/.github/workflows/deploy-pages.yml
@@ -29,12 +29,13 @@ jobs:
       - name: Build static site
         run: |
           mkdir -p _site
-          cat site.part00 site.part01 site.part02 site.part03 site.part04 \
+          cat site.part00 site.part01 site.part02 site.part03 site.part04 site.part05 \
             | base64 --decode \
             | tar -xz -C _site
           test -f _site/index.html
           test -f _site/restaurants/index.html
           test -f _site/assets/site.css
+          test -f _site/assets/home-photo-rotator.js
           test -f _site/assets/site.js
 
       - name: Enable existing site photos
@@ -45,79 +46,17 @@ jobs:
       - name: Add uploaded venue photos
         run: |
           mkdir -p _site/images
